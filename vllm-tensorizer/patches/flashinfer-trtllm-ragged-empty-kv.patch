+                        ),
+                        torch.cumsum(run_seq_lens, dim=0, dtype=cum_seq_lens_kv.dtype),
+                    ],
+                    dim=0,
+                )
+                run_max_q_len = int(run_q_lens.max().item())
+                run_max_kv_len = int(run_seq_lens.max().item())
+                run_batch_size = int(active_indices.numel())
+                run_out = torch.empty(
+                    run_query.shape[0],
+                    query.shape[1],
+                    value.shape[2],
+                    device=query.device,
+                    dtype=out.dtype,
+                )
+                run_lse = (
+                    torch.empty(
+                        run_query.shape[0],
+                        query.shape[1],
+                        device=query.device,
+                        dtype=torch.float32,
+                    )
+                    if lse is not None
+                    else None
+                )
+
